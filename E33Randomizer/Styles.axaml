<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e33Randomizer="clr-namespace:E33Randomizer"
        xmlns:uiControls="clr-namespace:E33Randomizer.UIControls">
    <Design.PreviewWith>
        
        <Border Padding="20">
            <StackPanel Spacing="20">
                <TextBlock Classes="e33PageHeader">TextBlock (class "e33PageHeader")</TextBlock>
                <TextBlock>This is a TextBlock</TextBlock>
                <Button Classes="e33Button">A button with the e33Button class.</Button>
                <Button Classes="e33Button Green">A button with the e33Button + Green class.</Button>
                <Button Classes="e33DeleteButton" />
                <CheckBox>This is a checkbox</CheckBox>
                <Grid ColumnDefinitions="*,*" Margin="20" Width="300" HorizontalAlignment="Left">
                    <Label Grid.Column="0" >Numeric Up Down</Label>
                    <NumericUpDown
                        Grid.Column="1"
                        ShowButtonSpinner="True"
                        ButtonSpinnerLocation="Right"
                        Text="1234"
                        FormatString="0"
                        Minimum="0"
                        Width="200"
                        Maximum="2000"
                        Increment="1"
                        Value="1234" FontSize="25" />
                </Grid>
                <TextBlock Classes="note">This is some warning/important info text.</TextBlock>
                <Grid ColumnDefinitions="*,*" Margin="20" Width="200" HorizontalAlignment="Left">
                
                <Label Grid.Column="0" Content="This is a Slider" />
                <Slider Grid.Column="1" Width="100"
                        Height="30"
                        Minimum="0"
                        Maximum="100"
                        Name="Slider"
                        Margin="0, 0, 10, 0"
                        Padding="0 0 0 15"
                        VerticalAlignment="Center" />
                </Grid>
                <uiControls:SubSection Header="Test" ToolTipContent="This is a tooltip content block" ToolTipHeader="This is a tooltip">
                    <TextBlock Text="Value"/>
                </uiControls:SubSection>
            </StackPanel>
        </Border>
    </Design.PreviewWith>
    <FluentTheme>
        <FluentTheme.Palettes>
            <ColorPaletteResources x:Key="Light" Accent="#DAAF7D" AltHigh="White" AltLow="White" AltMedium="White"
                                   AltMediumHigh="White" AltMediumLow="White" BaseHigh="#080105" BaseLow="#ffcccccc"
                                   BaseMedium="#ff898989" BaseMediumHigh="#ff5d5d5d" BaseMediumLow="#ff737373"
                                   ChromeAltLow="#ff5d5d5d" ChromeBlackHigh="#080105" ChromeBlackLow="#ffcccccc"
                                   ChromeBlackMedium="#ff5d5d5d" ChromeBlackMediumLow="#ff898989"
                                   ChromeDisabledHigh="#ffcccccc" ChromeDisabledLow="#ff898989" ChromeGray="#ff737373"
                                   ChromeHigh="#ffcccccc" ChromeLow="#ffececec" ChromeMedium="#ffe6e6e6"
                                   ChromeMediumLow="#ffececec" ChromeWhite="White" ListLow="#ffe6e6e6"
                                   ListMedium="#ffcccccc" RegionColor="White" />
            <ColorPaletteResources x:Key="Dark" Accent="#DAAF7D" AltHigh="#080105" AltLow="#080105" AltMedium="#080105"
                                   AltMediumHigh="#080105" AltMediumLow="#080105" BaseHigh="White" BaseLow="#ff333333"
                                   BaseMedium="#ff9a9a9a" BaseMediumHigh="#ffb4b4b4" BaseMediumLow="#ff676767"
                                   ChromeAltLow="#ffb4b4b4" ChromeBlackHigh="#080105" ChromeBlackLow="#ffb4b4b4"
                                   ChromeBlackMedium="#080105" ChromeBlackMediumLow="#080105"
                                   ChromeDisabledHigh="#ff333333" ChromeDisabledLow="#ff9a9a9a" ChromeGray="Gray"
                                   ChromeHigh="Gray" ChromeLow="#ff151515" ChromeMedium="#ff1d1d1d"
                                   ChromeMediumLow="#ff2c2c2c" ChromeWhite="White" ListLow="#ff1d1d1d"
                                   ListMedium="#ff333333" RegionColor="#080105" />
        </FluentTheme.Palettes>
    </FluentTheme>
    <Style Selector=":is(TopLevel)">
        <Setter Property="FontFamily" Value="fonts:E33Fonts#IM FELL Double Pica" />
    </Style>

    <!-- Buttons -->
    <Style Selector="Button.e33Button:pointerover Image#Left">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseHoverLeft.png" />
    </Style>
    <Style Selector="Button.e33Button:pointerover Image#Right">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseHoverRight.png" />
    </Style>
    <Style Selector="Button.e33Button.Green Image#Left">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseLeftGreen.png" />
    </Style>
    <Style Selector="Button.e33Button.Green Image#Right">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseRightGreen.png" />
    </Style>
    <Style Selector="Button.e33Button.Green Panel#Center">
        <Setter Property="Background" Value="#0e1a18" />
    </Style>
    <Style Selector="Button.e33Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#1b1918" />
    </Style>
    
    <Style Selector="Button.e33Button.Green:pointerover Image#Left">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseHoverLeftGreen.png" />
    </Style>
    <Style Selector="Button.e33Button.Green:pointerover Image#Right">
        <Setter Property="Source" Value="avares://E33Randomizer/Assets/Images/ButtonBaseHoverRightGreen.png" />
    </Style>
    <Style Selector="Button.e33Button.Green:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#122220" />
    </Style>
    <Style Selector="Button.e33Button.Green:pointerover Panel#Center">
        <Setter Property="Background" Value="#122220" />
    </Style>

    <Style Selector="Button.e33Button">
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontFamily" Value="fonts:E33Fonts#Cinzel" />
        <Setter Property="Background" Value="#1b1918" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid HorizontalAlignment="Center"
                      VerticalAlignment="Top" ColumnDefinitions="Auto,*,Auto">

                    <!-- Left background image -->
                    <Image Grid.Column="0" Name="Left"
                           Source="avares://E33Randomizer/Assets/Images/ButtonBaseLeft.png" Stretch="None" />

                    <!-- Middle transparent space (grows horizontally) -->
                    <Panel Grid.Column="1" Background="#1b1918" Name="Center" />

                    <!-- Right background image -->
                    <Image Grid.Column="2" Name="Right"
                           Source="avares://E33Randomizer/Assets/Images/ButtonBaseRight.png" Stretch="None" />

                    <!-- Floating Button, overlapping all columns -->
                    <ContentPresenter Grid.Column="0" Grid.ColumnSpan="3"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      ZIndex="1"
                                      Name="PART_ContentPresenter"
                                      Margin="20 0"
                                      Content="{TemplateBinding Content}" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <Style Selector="Button.e33DeleteButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="MaxHeight" Value="64" />
        <Setter Property="MaxWidth" Value="64" />
        <Setter Property="Template">
            <ControlTemplate>
                <!-- Right background image -->
                <Image Source="avares://E33Randomizer/Assets/Images/DeleteButton.png" Stretch="Fill" />
            </ControlTemplate>
        </Setter>
    </Style>
    

    <!-- NumericUpDown -->
    <Style Selector="NumericUpDown /template/ TextBox#PART_TextBox">
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Padding" Value="5 0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="fonts:E33Fonts#Bebas Neue" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="FontSize" Value="{TemplateBinding FontSize}" />

    </Style>

    <!-- Checkboxes -->
    <Style Selector="CheckBox">
        <Setter Property="FontSize" Value="18" />
    </Style>
    <Style Selector="CheckBox:checked /template/ Border#NormalRectangle">
        <Setter Property="Background" Value="black" />
    </Style>

    <!-- TextBlocks -->
    <Style Selector="TextBlock.note">
        <Setter Property="Foreground" Value="#DAAF7D" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="Margin" Value="40,5,0,5" />
    </Style>
    
    <Style Selector="TextBlock.e33PageHeader">
        <Setter Property="Foreground" Value="#DAAF7D" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontFamily" Value="fonts:E33Fonts#Cinzel" />
    </Style>

    <!-- Add Styles Here -->
</Styles>