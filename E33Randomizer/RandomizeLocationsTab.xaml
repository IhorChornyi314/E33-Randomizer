<UserControl x:Class="E33Randomizer.RandomizeLocationsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:E33Randomizer"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <CheckBox Content="Randomize locations"
                                  IsChecked="{Binding RandomizeLocations}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Name="RescaleLocationsCheckBox"
                            Content="Re-scale locations"
                                  IsChecked="{Binding RescaleLocations}"
                                  Margin="0,0,0,0"
                                  FontSize="14" /><StackPanel Orientation="Horizontal" Margin="0,0,0,0"
                                                              Visibility="{Binding IsChecked, ElementName=RescaleLocationsCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Label Content="Set the scaling modifier to"
                                   
                                   FontSize="14" />
                            <xctk:IntegerUpDown Text="{Binding ScaleModifierPercentage}"
                                                Margin="5,0,0,0"
                                                VerticalAlignment="Center"
                                                Maximum="9999"
                                                Minimum="0"
                                                Height="20"
                                                Width="50"
                                                FontSize="14"
                                                MaxLength="3" />
                            <Label Content="%"
                                   FontSize="14" />
                        </StackPanel>
                        <CheckBox Name="ScaleOptionalAreasCheckBox"
                                  Content="Re-scale optional areas"
                                  IsChecked="{Binding ScaleOptionalAreas}"
                                  Margin="0,0,0,0"
                                  FontSize="14" 
                                  Visibility="{Binding IsChecked, ElementName=RescaleLocationsCheckBox, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <CheckBox Content="Re-scale characters"
                                  IsChecked="{Binding RescaleCharacters}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Content="Randomize starting location"
                                  IsChecked="{Binding RandomizeStartingLocation}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Content="Randomize manor doors"
                                  IsChecked="{Binding RandomizeManorDoors}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Content="Randomize painting workshop entrances"
                                  IsChecked="{Binding RandomizeWorkshopEntries}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Content="Randomize cutscene teleports"
                                  IsChecked="{Binding RandomizeCutsceneTeleports}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        <CheckBox Content="Randomize gestral beaches"
                                  IsChecked="{Binding RandomizeGestralBeachPortals}"
                                  Margin="0,0,0,0"
                                  FontSize="14" />
                        
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <Button Name="CustomLocationPlacementButton"
                                Content="Customize Location Placements"
                                Width="500"
                                Height="50"
                                FontSize="20"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,20"
                                Background="Aqua"
                                Click="CustomPlacementButton_Click" 
                                Tag="Location" />
                        <Button Name="EditLocationsButton"
                                Content="Edit Individual Locations"
                                Width="500"
                                Height="50"
                                FontSize="20"
                                HorizontalAlignment="Center"
                                Margin="0,10,0,20"
                                Background="Aqua"
                                Click="EditButton_Click" 
                                Tag="Location" />
                    </StackPanel>
                </Grid>
    </Grid>
</UserControl>
