<Window x:Class="E33Randomizer.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:e33Randomizer="clr-namespace:E33Randomizer"
        Title="Expedition 33 Randomizer" Height="800" Width="1000"
        MinHeight="850" MinWidth="1000">
    <DockPanel x:DataType="e33Randomizer:SettingsViewModel">
        <Border DockPanel.Dock="Left" BorderBrush="#ffd4af37" BorderThickness="0,0,1,0" Margin="5">
            <Panel>
                <TabStrip SelectedIndex="{Binding SelectedIndex}" VerticalAlignment="Top" Cursor="Hand">
                    <TabStrip.Styles>
                        <Style Selector="ItemsPresenter#PART_ItemsPresenter > WrapPanel">
                            <Setter Property="Orientation" Value="Vertical" />
                        </Style>
                        <Style Selector="TabStripItem:selected /template/ Border#PART_SelectedPipe">
                            <Setter Property="Width" Value="3" />
                            <Setter Property="Height" Value="NaN" /> <!-- Auto height to stretch -->
                            <Setter Property="HorizontalAlignment" Value="Left" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="-5,4,0,4" />
                        </Style>
                    </TabStrip.Styles>
                    <TabStripItem>Enemy Randomizer</TabStripItem>
                    <TabStripItem>Item Randomizer</TabStripItem>
                    <TabStripItem>Skill Randomizer</TabStripItem>
                    <TabStripItem>Location Randomizer</TabStripItem>
                    <TabStripItem>Misc</TabStripItem>
                </TabStrip>

                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Spacing="10">
                    <Button x:Name="SavePresetButton"
                            Classes="isActionButton"
                            Background="#A4A4A4"
                            Content="Save settings JSON"
                            Width="200"
                            Click="SavePresetButton_Click"
                            FontWeight="Bold" />

                    <Button x:Name="LoadPresetButton"
                            Content="Load settings JSON"
                            Classes="isActionButton"
                            Background="#A4A4A4"
                            Width="200"
                            Click="LoadPresetButton_Click"
                            FontWeight="Bold" />

                    <!-- Generate Button -->
                    <Button x:Name="GenerateButton"
                            Classes="isActionButton"
                            Content="Generate and pack"
                            Width="200"
                            Click="GenerateButton_Click"
                            FontWeight="Bold" />

                    <!-- Seed Input -->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Seed:" VerticalAlignment="Center" FontWeight="Bold" />
                        <NumericUpDown x:DataType="e33Randomizer:SettingsViewModel" x:Name="SeedTextBox"
                                       Text="{Binding Seed}"
                                       ShowButtonSpinner="False"
                                       Margin="10,0,20,0"
                                       VerticalAlignment="Center"
                                       Maximum="2000000000"
                                       Minimum="-1"
                                       HorizontalAlignment="Left"
                                       Height="25"
                                       Width="100" />
                    </StackPanel>
                </StackPanel>
            </Panel>
        </Border>
        <ContentControl Content="{Binding CurrentPage}" />
    </DockPanel>
</Window>