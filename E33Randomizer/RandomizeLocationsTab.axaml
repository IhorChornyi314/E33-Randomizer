<UserControl x:Class="E33Randomizer.RandomizeLocationsTab"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:e33Randomizer="clr-namespace:E33Randomizer"
             xmlns:uiControls="clr-namespace:E33Randomizer.UIControls"
             xmlns:lang="clr-namespace:E33Randomizer.Assets"
             mc:Ignorable="d"
             d:DataContext="{x:Static e33Randomizer:DesignLocationSettingsViewModel.SettingsViewModel}"
             d:DesignHeight="{x:Static e33Randomizer:MainWindow.TabContainerHeight}"
             d:DesignWidth="{x:Static e33Randomizer:MainWindow.TabContainerWidth}">
    <Grid x:DataType="e33Randomizer:SettingsViewModel">
        <Grid Margin="20" RowDefinitions="Auto,*,Auto">
            <StackPanel>
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizeLocations}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizeLocations}"
                    IsChecked="{Binding RandomizeLocations}" />
                <uiControls:CheckboxToolTip
                    Name="RescaleLocationsCheckBox"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RescaleLocations}"
                    Content="{x:Static lang:Resources.Randomize_Locations_RescaleLocations}"
                    IsChecked="{Binding RescaleLocations}" />
                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding IsChecked, ElementName=RescaleLocationsCheckBox}">
                    <TextBlock Text="{x:Static lang:Resources.Randomize_Locations_SetScaleModifier}" 
                               Margin="30 0 0 0"/>
                    <NumericUpDown
                        Text="{Binding ScaleModifierPercentage}"
                        Value="{Binding ScaleModifierPercentage}"
                        Margin="5 0 0 0"
                        VerticalAlignment="Center"
                        FormatString="0"
                        Maximum="9999"
                        Minimum="0" />
                </StackPanel>
                <uiControls:CheckboxToolTip
                    Name="ScaleOptionalAreasCheckBox"
                    Content="{x:Static lang:Resources.Randomize_Locations_RescaleOptionalAreas}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RescaleOptionalAreas}"
                    IsChecked="{Binding ScaleOptionalAreas}"
                    IsVisible="{Binding IsChecked, ElementName=RescaleLocationsCheckBox}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RescaleCharacters}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RescaleCharacters}"
                    IsChecked="{Binding RescaleCharacters}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizeStartingLocation}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizeStartingLocation}"
                    IsChecked="{Binding RandomizeStartingLocation}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizeManorDoors}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizeManorDoors}"
                    IsChecked="{Binding RandomizeManorDoors}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizePaintingWorkshopEntrances}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizePaintingWorkshopEntrances}"
                    IsChecked="{Binding RandomizeWorkshopEntries}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizeCutsceneTeleports}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizeCutsceneTeleports}"
                    IsChecked="{Binding RandomizeCutsceneTeleports}" />
                <uiControls:CheckboxToolTip
                    Content="{x:Static lang:Resources.Randomize_Locations_RandomizeGestralBeaches}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Locations_Tooltip_RandomizeGestralBeaches}"
                    IsChecked="{Binding RandomizeGestralBeachPortals}" />
            </StackPanel>
            <Grid Grid.Row="2" ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Classes="e33Button"
                        Content="{x:Static lang:Resources.Randomize_Locations_Button_CustomizeLocationPlacements}"
                        Click="CustomPlacementButton_Click"
                        Tag="Location" />
                <Button Grid.Column="1"
                        Classes="e33Button"
                        Content="{x:Static lang:Resources.Randomize_Locations_Button_EditIndividualLocations}"
                        Click="EditButton_Click"
                        Tag="Location" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>