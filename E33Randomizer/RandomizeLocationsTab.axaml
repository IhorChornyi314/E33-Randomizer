<UserControl x:Class="E33Randomizer.RandomizeLocationsTab"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:E33Randomizer"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300">
    <Grid x:DataType="local:SettingsViewModel">
        <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel>
                        <CheckBox Content="Randomize locations"
                                  IsChecked="{Binding RandomizeLocations}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2">
                        <Button x:Name="CustomLocationPlacementButton"
                                Content="Customize Location Placements"
                                Width="500"
                                Height="50"
                                FontSize="20"
                                HorizontalAlignment="Center"
                                Click="CustomPlacementButton_Click" 
                                Tag="Location" />
                        <Button x:Name="EditLocationsButton"
                                Content="Edit Individual Locations"
                                Width="500"
                                Height="50"
                                FontSize="20"
                                HorizontalAlignment="Center"
                                Click="EditButton_Click" 
                                Tag="Location" />
                    </StackPanel>
                </Grid>
    </Grid>
</UserControl>
