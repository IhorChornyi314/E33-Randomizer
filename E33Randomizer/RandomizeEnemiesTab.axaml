<UserControl
    x:Class="E33Randomizer.RandomizeEnemiesTab"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:e33Randomizer="clr-namespace:E33Randomizer"
    xmlns:uiControls="clr-namespace:E33Randomizer.UIControls"
    xmlns:lang="clr-namespace:E33Randomizer.Assets"
    mc:Ignorable="d"
    d:DataContext="{x:Static e33Randomizer:DesignEnemiesSettingsViewModel.SettingsViewModel}"
    d:DesignHeight="850" d:DesignWidth="700">
    <Grid Margin="20" x:DataType="e33Randomizer:SettingsViewModel" RowDefinitions="Auto,*,Auto">
        <!-- Randomize Encounter Sizes -->
        <StackPanel Orientation="Vertical" Margin="0">
            <uiControls:CheckboxToolTip
                Content="{x:Static lang:Resources.Randomize_Enemies_RandomizeEnemies}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_RandomizeEnemies}"
                IsChecked="{Binding RandomizeEnemies}" />
            <Grid ColumnDefinitions="Auto,Auto,Auto,Auto">
                <uiControls:CheckboxToolTip
                    Grid.Column="0"
                    x:Name="RandomizeEncounterSizesCheckBox"
                    Content="{x:Static lang:Resources.Randomize_Enemies_RandomizeEncounterSizes}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_RandomizeEncounterSizes}"
                    IsChecked="{Binding RandomizeEncounterSizes}" />
                <CheckBox
                    Grid.Column="1"
                    x:Name="EncounterSize1CheckBox"
                    Tag="1"
                    Content="1"
                    IsChecked="{Binding EncounterSizeOne}"
                    Margin="20,0,0,0"
                    IsVisible="{Binding IsChecked, ElementName=RandomizeEncounterSizesCheckBox}" />
                <CheckBox
                    Grid.Column="2"
                    x:Name="EncounterSize2CheckBox"
                    Tag="2"
                    Content="2"
                    Margin="20,0,0,0"
                    IsChecked="{Binding EncounterSizeTwo}"
                    IsVisible="{Binding IsChecked, ElementName=RandomizeEncounterSizesCheckBox}" />
                <CheckBox
                    Grid.Column="3"
                    x:Name="EncounterSize3CheckBox"
                    Tag="3"
                    Content="3"
                    Margin="20,0,0,0"
                    IsChecked="{Binding EncounterSizeThree}"
                    IsVisible="{Binding IsChecked, ElementName=RandomizeEncounterSizesCheckBox}" />
            </Grid>

            <StackPanel Orientation="Vertical" Margin="0">
                <uiControls:CheckboxToolTip
                    x:Name="ChangeSizeOfNonRandomEncountersCheckBox"
                    Content="{x:Static lang:Resources.Randomize_Enemies_ChangeSizeOfEncounters}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ChangeSizeOfEncounters}"
                    IsChecked="{Binding ChangeSizeOfNonRandomizedEncounters}"
                    IsVisible="{Binding IsChecked, ElementName=RandomizeEncounterSizesCheckBox}" />
            </StackPanel>

            <!-- Randomize Merchant Fights -->
            <uiControls:CheckboxToolTip
                x:Name="RandomizeMerchantFightsCheckBox"
                Content="{x:Static lang:Resources.Randomize_Enemies_RandomizeMerchantFights}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_RandomizeMerchantFights}"
                IsChecked="{Binding RandomizeMerchantFights}" />
            <StackPanel Orientation="Vertical" Margin="0">
                <!-- <CheckBox x:Name="TieLootToEncountersButton" -->
                <!--           Content="Tie loot drops to encounters instead of enemies" -->
                <!--           IsChecked="True" -->
                <!--           Margin="0" -->
                <!--           FontSize="14"/> -->
                <TextBlock Text="{x:Static lang:Resources.Randomize_Enemies_RandomizeMerchantFights_Note}"
                           Classes="note" />
            </StackPanel>
            <!-- Include Cut Content -->
            <StackPanel Orientation="Vertical" Margin="0">
                <uiControls:CheckboxToolTip
                    x:Name="IncludeCutContentCheckBox"
                    Content="{x:Static lang:Resources.Randomize_Enemies_IncludeCutContent}"
                    ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_IncludeCutContent}"
                    IsChecked="{Binding IncludeCutContentEnemies}" />

                <TextBlock
                    Text="{x:Static lang:Resources.Randomize_Enemies_IncludeCutContent_Note}"
                    Classes="note"
                    IsVisible="{Binding IsChecked, ElementName=IncludeCutContentCheckBox}" />
            </StackPanel>

            <uiControls:CheckboxToolTip
                x:Name="EnableEnemyOnslaughtCheckBox"
                Content="{x:Static lang:Resources.Randomize_Enemies_EnableEnemyOnslaught}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_EnableEnemyOnslaught}"
                IsChecked="{Binding EnableEnemyOnslaught}" />

            <StackPanel Orientation="Vertical"
                        IsVisible="{Binding IsChecked, ElementName=EnableEnemyOnslaughtCheckBox}">
                <TextBlock
                    Text="{x:Static lang:Resources.Randomize_Enemies_EnableEnemyOnslaught_Note}"
                    Classes="note" />
                <CheckBox
                    x:Name="RandomizeAdditionalEnemiesCheckBox"
                    Content="{x:Static lang:Resources.Randomize_Enemies_EnableEnemyOnslaught_RandomizeAddedEnemies}"
                    IsChecked="{Binding RandomizeAddedEnemies}" />
                <Grid ColumnDefinitions="Auto, Auto" RowDefinitions="*,*" RowSpacing="4" Margin="40 0 0 0">
                    <Label Grid.Row="0" Grid.Column="0"
                           VerticalContentAlignment="Center"
                           Content="{x:Static lang:Resources.Randomize_Enemies_EnableEnemyOnslaught_NumberOfAdditionalEnemies}" HorizontalAlignment="Right" />
                    <NumericUpDown
                        Grid.Row="0"
                        Grid.Column="1"
                        x:Name="NumberOfAdditionalEnemiesTextBox"
                        Text="{Binding EnemyOnslaughtAdditionalEnemies, Mode=OneWay}"
                        Value="{Binding EnemyOnslaughtAdditionalEnemies}"
                        Margin="5 0 0 0"
                        FormatString="0"
                        Maximum="99"
                        Minimum="1"
                        HorizontalAlignment="Right"/>
                    <Label Grid.Row="1" Grid.Column="0"
                        VerticalContentAlignment="Center"
                        Content="{x:Static lang:Resources.Randomize_Enemies_EnableEnemyOnslaught_CapEncounterSizesAt}" 
                        HorizontalAlignment="Right"/>
                    <NumericUpDown
                        Grid.Row="1" Grid.Column="1" x:Name="EnemyNumberCapTextBox"
                        Text="{Binding EnemyOnslaughtEnemyCap, Mode=OneWay}"
                        Value="{Binding EnemyOnslaughtEnemyCap}"
                        HorizontalAlignment="Right"
                        FormatString="0"
                        Maximum="99"
                        Minimum="1" />
                </Grid>
            </StackPanel>
            <uiControls:CheckboxToolTip
                x:Name="EnsureBossesInBossEncountersCheckBox"
                Content="{x:Static lang:Resources.Randomize_Enemies_EnsureEncountersAtLeastOne}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_EnsureEncountersAtLeastOne}"
                IsChecked="{Binding EnsureBossesInBossEncounters}" />

            <uiControls:CheckboxToolTip
                x:Name="ReduceBossRepetitionCheckBox"
                Content="{x:Static lang:Resources.Randomize_Enemies_ReduceBossRepetition}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReduceBossRepetition}"
                IsChecked="{Binding ReduceBossRepetition}" />

            <uiControls:CheckboxToolTip
                Content="{x:Static lang:Resources.Randomize_Enemies_ReplacePhase2Simon}"
                ToolTipContent="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2Simon}"
                IsChecked="{Binding NoSimonP2BeforeLune}" />

            <!-- Phase 2 Simon Dropdown -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,20"
                        IsVisible="False">
                <Label Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter}" />
                <!-- SelectedItem="{Binding EarliestSimonP2Encounter}" -->
                <ComboBox x:Name="Phase2SimonComboBox"
                          HorizontalAlignment="Left">
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_Lune}"
                        IsSelected="True" Tag="SM_Eveque_ShieldTutorial*1" />
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_Eveque}"
                        Tag="GO_Curator_JumpTutorial*1" />
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_Goblu}"
                        Tag="AS_PotatoBag_Boss" />
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_UltimateSakapatate}"
                        Tag="QUEST_MatthieuTheColossus*1" />
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_GestralTournament}"
                        Tag="EN_Francois" />
                    <ComboBoxItem
                        Content="{x:Static lang:Resources.Randomize_Enemies_Tooltip_ReplacePhase2SimonUntilAfter_Never}"
                        Tag="SM_Lancelier*1" />
                </ComboBox>
            </StackPanel>
        </StackPanel>
        <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <Button Grid.Column="0" x:Name="CustomEnemyPlacementButton"
                    Content="{x:Static lang:Resources.Randomize_Enemies_Button_EditEnemyPlacements}"
                    Click="CustomPlacementButton_Click"
                    Tag="Enemy"
                    Classes="e33Button" />
            <Button Grid.Column="1" x:Name="EditEncountersButton"
                    Content="{x:Static lang:Resources.Randomize_Enemies_Button_EditIndividualEncounters}"
                    Click="EditButton_Click"
                    Classes="e33Button"
                    Tag="Enemy" />
        </Grid>
    </Grid>
</UserControl>