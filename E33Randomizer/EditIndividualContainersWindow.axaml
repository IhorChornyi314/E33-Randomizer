<Window x:Class="E33Randomizer.EditIndividualContainersWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:E33Randomizer"
        Title="Edit Individual Encounters" Height="725" Width="900" MinHeight="725" MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="5" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.ColumnSpan="3">
            <Label x:Name="SearchLabel" VerticalAlignment="Center" Margin="10" FontSize="15"
                   Content="Search by encounter or enemy names:">
            </Label>
            <TextBox x:Name="SearchTextBox"
                     Margin="0,5,0,0"
                     VerticalAlignment="Center"
                     Height="25"
                     Width="600"
                     TextChanged="SearchTextBox_OnTextChanged" />
        </StackPanel>
        <DockPanel Grid.Row="1" Grid.Column="0" Margin="10">
            <TextBlock x:Name="ContainersTextBlock" Text="Encounters" FontWeight="Bold" FontSize="14"
                       DockPanel.Dock="Top" Margin="0,0,0,10" />

            <TreeView x:Name="LocationTreeView"
                      SelectionChanged="CategoryTreeView_SelectedItemChanged"
                      SelectionMode="Single"
                      x:DataType="local:EditIndividualObjectsWindowViewModel"
                      ItemsSource="{Binding FilteredCategories}">
                <TreeView.DataTemplates>

                    <TreeDataTemplate DataType="{x:Type local:CategoryViewModel}"
                                      ItemsSource="{Binding Containers}">
                        <TextBlock Text="{Binding CategoryName}" FontWeight="Bold" FontSize="13"
                                   Margin="2" />
                    </TreeDataTemplate>

                    <DataTemplate DataType="{x:Type local:ContainerViewModel}">
                        <TextBlock Text="{Binding Name}" Margin="5,2"
                                   FontSize="12" />
                    </DataTemplate>
                </TreeView.DataTemplates>
            </TreeView>
        </DockPanel>

        <GridSplitter Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Background="#E0E0E0" />

        <DockPanel Grid.Row="1" Grid.Column="2" Margin="10">
            <TextBlock x:Name="ObjectsTextBlock" Text="Enemies in the encounter" FontWeight="Bold" FontSize="14"
                       DockPanel.Dock="Top" Margin="0,0,0,10" />

            <ListBox DockPanel.Dock="Top" Height="350" x:Name="SelectedEnemiesListBox"
                     x:DataType="local:EditIndividualObjectsWindowViewModel"
                     ItemsSource="{Binding DisplayedObjects}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Margin="0,0,0,10">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:ObjectViewModel}">
                        <Grid Margin="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox Grid.Column="0"
                                                ItemsSource="{Binding AllObjects}"
                                                SelectedItem="{Binding SelectedComboBoxValue, Mode=TwoWay}"
                                                VerticalAlignment="Center"
                                                Margin="5,2"
                                                MinWidth="200">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <NumericUpDown Grid.Column="1" x:Name="NumberOfAdditionalEnemiesTextBox"
                                           Text="{Binding IntProperty}"
                                           Margin="5,0,0,0"
                                           VerticalAlignment="Center"
                                           Height="25"
                                           Width="50"
                                           FontSize="16"
                                           Minimum="0"
                                           Maximum="99"
                                           IsVisible="{Binding HasIntPropertyControl}" />
                            <LayoutTransformControl Grid.Column="2">
                                <LayoutTransformControl.LayoutTransform>
                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                </LayoutTransformControl.LayoutTransform>
                                <CheckBox 
                                    VerticalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Margin="10,0,0,0"
                                    Height="25"
                                    Width="25"
                                    IsChecked="{Binding BoolProperty}"
                                    IsVisible="{Binding HasBoolPropertyControl}">
                                </CheckBox>
                            </LayoutTransformControl>
                            
                            <Button Grid.Column="3" Content="✕" Width="20" Height="20"
                                    FontSize="10" Margin="0"
                                    Click="RemoveObject_Click"
                                    Tag="{Binding}"
                                    ToolTip.Tip="Remove"
                                    IsVisible="{Binding CanDelete}"
                                    />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>


            <StackPanel DockPanel.Dock="Bottom">
                <TextBlock x:Name="AddObjectTextBlock" Text="Add Enemy:" Margin="0,0,0,5" FontWeight="SemiBold" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <AutoCompleteBox x:Name="AddObjectComboBox"
                                     x:DataType="local:EditIndividualObjectsWindowViewModel"
                                     Grid.Column="0"
                                     ItemsSource="{Binding AddObjectsView}"
                                     SelectedItem="{Binding SelectedAddObject, Mode=TwoWay}"
                                     IsEnabled="{Binding CanAddObjects}"
                                     FilterMode="Contains"
                                     IsDropDownOpen="True"
                                     Text="{Binding AddObjectFilterTerm, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="200"
                                     Margin="0,0,10,0"
                                     Loaded="AddObjectComboBox_Loaded"
                                     GotFocus="AddObjectComboBox_GotKeyboardFocus"/>

                    <Button x:Name="AddObjectButton"
                            x:DataType="local:EditIndividualObjectsWindowViewModel"
                            Grid.Column="1"
                            Content="Add"
                            Width="60"
                            Height="25"
                            Click="AddObjectButton_Click"
                            IsEnabled="{Binding CanAddObjects}"
                            VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="LoadTextButton" Content="Load encounters from .txt file" Width="180" Height="30"
                            Margin="0,0,10,0" Click="ReadDataFromTxt" />
                    <Button x:Name="SaveTextButton" Content="Save encounters to .txt file" Width="180" Height="30"
                            Click="SaveDataAsTxt" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="RegenerateEncountersButton" Content="Reroll with current settings" Width="180"
                            Height="30"
                            Margin="0,0,10,0" Click="RegenerateData" />
                    <Button x:Name="PackCurrentEncountersButton" Content="Generate mod files from current" Width="180"
                            Height="30"
                            Click="PackCurrentData" />
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>