<Window x:Class="E33Randomizer.CustomPlacements.CustomPlacementWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{x:Static lang:Resources.CustomPlacement_Title}" Height="900"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        SizeToContent="Width"
        xmlns:uiControls="clr-namespace:E33Randomizer.UIControls"
        xmlns:customPlacements="clr-namespace:E33Randomizer.CustomPlacements"
        xmlns:lang="clr-namespace:E33Randomizer.Assets"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:DataType="customPlacements:CustomPlacementWindowViewModel"
        x:Name="Root"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="900" d:DesignWidth="1300">
    <Window.Resources>
        <customPlacements:CustomPlacementValueConverter x:Key="CustomPlacementValueConverter" />
        <customPlacements:CustomPlacementResourceLookupConverter x:Key="ResourceLookupConverter" />
    </Window.Resources>
    <Window.Styles>
        <Style Selector="ComboBox.category /template/ Popup#PART_Popup">
            <Setter Property="Placement"
                    Value="BottomEdgeAlignedLeft" />
            <Setter Property="MinWidth" Value="300" />
        </Style>
        <Style Selector="ComboBox.category /template/ ScrollViewer">
            <Setter Property="MinWidth" Value="400" />
        </Style>
        <Style Selector="ComboBox.category DataValidationErrors">
            <Setter Property="Template">
                <ControlTemplate>
                    <DockPanel LastChildFill="True">
                        <ContentControl DockPanel.Dock="Right" Name="PART_ErrorContentControl"
                                        ContentTemplate="{TemplateBinding ErrorTemplate}"
                                        DataContext="{TemplateBinding Owner}"
                                        Content="{Binding (DataValidationErrors.Errors)}"
                                        IsVisible="{Binding (DataValidationErrors.HasErrors)}" />
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          CornerRadius="{TemplateBinding CornerRadius}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Content="{TemplateBinding Content}"
                                          Padding="{TemplateBinding Padding}" />
                    </DockPanel>
                </ControlTemplate>
            </Setter>
            <Setter Property="ErrorTemplate">
                <DataTemplate x:DataType="{x:Type x:Object}">
                    <Canvas Width="24" Height="24" Margin="4 0 1 0"
                            Background="Transparent">
                        <Canvas.Styles>
                            <Style Selector="ToolTip">
                                <Setter Property="Background" Value="Black" />
                                <Setter Property="BorderBrush" Value="Red" />
                            </Style>
                        </Canvas.Styles>
                        <ToolTip.Tip>
                            <ItemsControl ItemsSource="{Binding}" />
                        </ToolTip.Tip>
                        <Path Data="{StaticResource error_circle_regular}"
                              VerticalAlignment="Center"
                              Stroke="Red"
                              StrokeThickness="1" />
                    </Canvas>
                </DataTemplate>
            </Setter>
        </Style>
    </Window.Styles>
    <DockPanel FlowDirection="LeftToRight">

        <DockPanel LastChildFill="False" DockPanel.Dock="Left" Width="900">
            <DockPanel.Background>
                <ImageBrush Source="avares://E33Randomizer/Assets/Images/BackgroundOne.png" Stretch="Fill" Opacity="0.7" />
            </DockPanel.Background>
            <StackPanel Orientation="Vertical" MaxHeight="800" DockPanel.Dock="Top">
                <TextBlock Classes="e33PageHeader"
                           Margin="0 10"
                           HorizontalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource ResourceLookupConverter}">
                            <Binding Path="EntityType" />
                            <Binding Source="{x:Static customPlacements:CustomPlacementWindowViewModel.TitleResxName }" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TabControl>
                    <TabControl.Styles>
                        <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
                            <Setter Property="Margin" Value="20 0 0 0" />
                        </Style>
                    </TabControl.Styles>
                    <TabControl.PageTransition>
                        <CrossFade Duration="0:0:0.2" />
                    </TabControl.PageTransition>
                    <TabItem Header="{x:Static lang:Resources.CustomPlacement_TabItem_SpecialRules}">
                        <Grid Margin="10" ColumnDefinitions="*,*">

                            <!-- Not Randomized Object Selection -->
                            <uiControls:SubSection Grid.Column="0" Width="400" xml:space="preserve"
                                                   Header="{x:Static lang:Resources.CustomPlacement_Header_NotRandomized}">
                                <uiControls:SubSection.ToolTipContent>
                                    <MultiBinding Converter="{StaticResource ResourceLookupConverter}">
                                        <Binding Path="EntityType" />
                                        <Binding
                                            Source="{x:Static customPlacements:CustomPlacementWindowViewModel.NotRandomizedResxName }" />
                                    </MultiBinding>
                                </uiControls:SubSection.ToolTipContent>
                                <StackPanel Margin="0 10 0 0">
                                    <AutoCompleteBox x:Name="NotRandomizedObjectsSelectionComboBox"
                                                     ItemsSource="{Binding NotRandomizedOptions}"
                                                     FilterMode="Contains"
                                                     MinimumPrefixLength="0"
                                                     SelectionChanged="NotRandomizedObjectsComboBox_SelectionChanged"
                                                     Width="380"
                                                     PlaceholderText="{x:Static lang:Resources.SearchPlaceholder}" />


                                    <ItemsControl ItemsSource="{Binding NotRandomized, Mode=TwoWay}" Margin="0 10 0 0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                                    <Button x:Name="RemoveNotRandomizedObjectButton"
                                                            Width="30" Height="30" Margin="0 0 5 0"
                                                            Classes="e33DeleteButton"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding #Root.((customPlacements:CustomPlacementWindowViewModel)DataContext).RemoveNotRandomizedCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    <TextBlock Text="{Binding .}" Height="30"
                                                               VerticalAlignment="Center" LineHeight="30" />

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </uiControls:SubSection>

                            <!-- Excluded Object Selection -->
                            <uiControls:SubSection Grid.Column="1"
                                                   Header="{x:Static lang:Resources.CustomPlacement_Header_Excluded}"
                                                   Width="400"
                                                   xml:space="preserve">
                                <uiControls:SubSection.ToolTipContent>
                                    <MultiBinding Converter="{StaticResource ResourceLookupConverter}">
                                        <Binding Path="EntityType" />
                                        <Binding
                                            Source="{x:Static customPlacements:CustomPlacementWindowViewModel.ExcludedResxName }" />
                                    </MultiBinding>
                                </uiControls:SubSection.ToolTipContent>

                                <StackPanel Margin="0 10 0 0">
                                    <AutoCompleteBox x:Name="ExcludedObjectsSelectionComboBox"
                                                     ItemsSource="{Binding ExcludedOptions}"
                                                     PlaceholderText="{x:Static lang:Resources.SearchPlaceholder}"
                                                     FilterMode="Contains"
                                                     MinimumPrefixLength="0"
                                                     Width="380"
                                                     SelectionChanged="NotExcludedObjectsComboBox_SelectionChanged" />

                                    <ItemsControl ItemsSource="{Binding Excluded, Mode=TwoWay}" Margin="0 10 0 0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                                    <Button x:Name="RemoveNotRandomizedObjectButton"
                                                            Width="30" Height="30" Margin="0 0 5 0"
                                                            Classes="e33DeleteButton"
                                                            HorizontalAlignment="Center"
                                                            Command="{Binding #Root.((customPlacements:CustomPlacementWindowViewModel)DataContext).RemoveExcludedCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    <TextBlock Text="{Binding .}" Height="30"
                                                               VerticalAlignment="Center" LineHeight="30" />

                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </uiControls:SubSection>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{x:Static lang:Resources.CustomPlacement_TabItem_AddCustomPlacements}">
                        <Grid Margin="10" ColumnDefinitions="*,*">

                            <!-- Left Column - Object Selection -->
                            <uiControls:SubSection Grid.Column="0"
                                                   Header="{x:Static lang:Resources.CustomPlacement_Header_SelectCategory}"
                                                   Margin="0,0,5,0"
                                                   Width="400">
                                <uiControls:SubSection.ToolTipContent>

                                    <MultiBinding Converter="{StaticResource ResourceLookupConverter}">
                                        <Binding Path="EntityType" />
                                        <Binding
                                            Source="{x:Static customPlacements:CustomPlacementWindowViewModel.CustomPlacementResxName }" />
                                    </MultiBinding>
                                </uiControls:SubSection.ToolTipContent>
                                <StackPanel Height="600">
                                    <TextBox PlaceholderText="{x:Static lang:Resources.SearchPlaceholder}"
                                             Text="{Binding CustomPlacementSearch}" />
                                    <ListBox x:Name="CustomPlacementObjectListBox"
                                             ItemsSource="{Binding FilteredCustomPlacementOptions }"
                                             SelectionMode="Single" Height="540">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnDefinitions="*,auto">
                                                    <TextBlock Grid.Column="0" Text="{Binding Item1}" />
                                                    <TextBlock Grid.Column="1" Text="*" IsVisible="{Binding Item2}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                        <ListBox.SelectedItem>
                                            <MultiBinding Converter="{StaticResource CustomPlacementValueConverter}"
                                                          Mode="OneWay">
                                                <Binding Path="#CustomPlacementObjectListBox.SelectedItem" />
                                                <Binding
                                                    Path="#Root.((customPlacements:CustomPlacementWindowViewModel)DataContext)" />
                                            </MultiBinding>
                                        </ListBox.SelectedItem>
                                    </ListBox>
                                </StackPanel>

                            </uiControls:SubSection>

                            <!-- Right Column - Frequency Adjustment for Selected Object -->
                            <uiControls:SubSection Grid.Column="1"
                                                   Header="{x:Static lang:Resources.CustomPlacement_Header_IsReplacedBy}"
                                                   Width="400">
                                <Grid RowDefinitions="Auto,*,Auto" Height="600">

                                    <!-- Selected Object Display -->
                                    <TextBlock Grid.Row="0" x:Name="SelectedObjectDisplay"
                                               Text="{x:Static lang:Resources.NothingSelected}"
                                               Margin="0,0,0,10"
                                               HorizontalAlignment="Center"
                                               IsVisible="{Binding SelectedCustomPlacementRuleName, Converter={x:Static ObjectConverters.IsNull}, Mode=OneWay}" />

                                    <!-- Scrollable Container for Custom Placement Rows -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding SelectedCustomPlacementRule, Mode=TwoWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                                        <Button Width="30" Height="30" Margin="0 0 5 0"
                                                                Classes="e33DeleteButton"
                                                                Command="{Binding #Root.((customPlacements:CustomPlacementWindowViewModel)DataContext).RemoveCustomPlacementCommand}"
                                                                CommandParameter="{Binding Key}"
                                                                ToolTip.Tip="{x:Static lang:Resources.ToolTip_Remove}" />
                                                        <ComboBox Width="150" Height="30" Margin="0 0 10 0"
                                                                  VerticalAlignment="Center"
                                                                  ItemsSource="{Binding #Root.((customPlacements:CustomPlacementWindowViewModel)DataContext).CustomPlacementOptions}"
                                                                  SelectedItem="{Binding Key, Mode=TwoWay}"
                                                                  Name="CustomPlacementCategoryComboBox"
                                                                  Classes="category" />


                                                        <Slider Width="100"
                                                                Height="30"
                                                                Minimum="0"
                                                                Maximum="100"
                                                                Name="Slider"
                                                                Value="{Binding Value, Mode=TwoWay, Delay=200}"
                                                                Margin="0, 0, 10, 0"
                                                                Padding="0 0 0 15"
                                                                VerticalAlignment="Center" />
                                                        <NumericUpDown
                                                            Width="60" Height="30"
                                                            Value="{Binding #Slider.Value, Mode=TwoWay}"
                                                            FormatString="{}{0:N0}%"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            ShowButtonSpinner="False"
                                                            VerticalAlignment="Center"
                                                            VerticalContentAlignment="Center" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Add Row Button -->
                                    <Button Grid.Row="2" x:Name="AddCustomPlacementRowButton"
                                            Margin="0 0 0 20"
                                            Content="{x:Static lang:Resources.CustomPlacement_Button_AddPlacementRow}"
                                            Classes="e33Button Green"
                                            HorizontalAlignment="Center"
                                            Command="{Binding AddCustomPlacementCommand}"
                                            IsVisible="{Binding SelectedCustomPlacementRuleName, Converter={x:Static ObjectConverters.IsNotNull}}" />
                                </Grid>
                            </uiControls:SubSection>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{x:Static lang:Resources.CustomPlacement_TabItem_FrequencyAdjustments}">
                        <uiControls:SubSection 
                                               Header="{x:Static lang:Resources.CustomPlacement_Header_Adjustments}">
                            <uiControls:SubSection.ToolTipContent>
                                <MultiBinding Converter="{StaticResource ResourceLookupConverter}">
                                    <Binding Path="EntityType" />
                                    <Binding
                                        Source="{x:Static customPlacements:CustomPlacementWindowViewModel.FrequencyAdjustmentResxName }" />
                                </MultiBinding>
                            </uiControls:SubSection.ToolTipContent>
                            <Grid Margin="10" RowDefinitions="*,Auto">
                                <!-- Scrollable Container for Frequency Rows -->
                                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding FrequencyAdjustments, Mode=TwoWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 5">
                                                    <Button Content="-" Width="30" Height="30" Margin="0 0 5 0"
                                                            Classes="e33DeleteButton"
                                                            Command="{Binding $parent[ItemsControl].((customPlacements:CustomPlacementWindowViewModel)DataContext).RemoveFrequencyRowCommand}"
                                                            CommandParameter="{Binding ., Mode=OneWay}" />

                                                    <ComboBox Width="300" Height="30" Margin="0 0 10 0"
                                                              VerticalAlignment="Center"
                                                              ItemsSource="{Binding #Root.((customPlacements:CustomPlacementWindowViewModel)DataContext).CustomPlacementOptions}"
                                                              SelectedValue="{Binding Key, Mode=TwoWay}"
                                                              Name="FrequencyAdjustmentsCategoryComboBox"
                                                              Classes="category" />
                                                    <Slider Width="100"
                                                            Height="30"
                                                            Minimum="0"
                                                            Maximum="100"
                                                            Name="Slider"
                                                            Value="{Binding Value, Mode=TwoWay, Delay=200}"
                                                            Margin="0, 0, 10, 0"
                                                            Padding="0 0 0 15"
                                                            VerticalAlignment="Center" />
                                                    <NumericUpDown
                                                        Width="60" Height="30"
                                                        Value="{Binding #Slider.Value, Mode=TwoWay}"
                                                        FormatString="{}{0:N0}%"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        ShowButtonSpinner="False"
                                                        VerticalAlignment="Center"
                                                        VerticalContentAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>


                                <!-- Add Row Button -->
                                <Button Grid.Row="1"
                                        Content="{x:Static lang:Resources.CustomPlacement_Button_AddFrequencyRow}"
                                        Classes="e33Button Green"
                                        Command="{Binding AddFrequencyRowCommand}"
                                        CommandParameter="" />
                            </Grid>
                        </uiControls:SubSection>
                    </TabItem>
                </TabControl>
            </StackPanel>

            <Border DockPanel.Dock="Bottom" BorderBrush="White" Margin="0 0 0 20">
                <!-- Close Button -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button Content="{x:Static lang:Resources.CustomPlacement_Button_QuickPresets}" Classes="e33Button">
                        <Button.Flyout>
                            <MenuFlyout ItemsSource="{Binding PresetFiles}">
                                <MenuFlyout.ItemContainerTheme>
                                    <ControlTheme TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}"
                                                  x:DataType="uiControls:MenuItemViewModel">

                                        <Setter Property="Header" Value="{Binding Name}" />
                                        <Setter Property="Command"
                                                Value="{Binding $parent[ItemsControl].((customPlacements:CustomPlacementWindowViewModel)DataContext).LoadFromJsonCommand}" />
                                        <Setter Property="CommandParameter" Value="{Binding FilePath}" />
                                        <Setter Property="StaysOpenOnClick" Value="False" />
                                    </ControlTheme>
                                </MenuFlyout.ItemContainerTheme>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <ComboBox x:Name="OopsAllObjectComboBox" Height="30"
                              IsVisible="{Binding SelectedPresetIsOops}"
                              ItemsSource="{Binding OopsAllObjects}"
                              SelectedItem="{Binding OopsAllObjectsSelection}"
                              SelectionChanged="OopsAllObjectComboBox_OnSelectionChanged" />
                    <Button Classes="e33Button"
                            x:Name="LoadPresetButton"
                            Content="{x:Static lang:Resources.CustomPlacement_Button_LoadPresetJson}"
                            Click="LoadPresetButton_Click" />

                    <Button Classes="e33Button"
                            x:Name="SavePresetButton"
                            Content="{x:Static lang:Resources.CustomPlacement_Button_SavePresetJson}"
                            Click="SavePresetButton_Click" />
                    <Button Classes="e33Button"
                            x:Name="CloseButton"
                            Content="{x:Static lang:Resources.Button_Close}"
                            Click="CloseButton_Click" />

                </StackPanel>
            </Border>
        </DockPanel>
        <Expander DockPanel.Dock="Right" ExpandDirection="Right" Height="900" MinWidth="48">
            <Expander.Header>

                <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0 40 0 0">
                    <TextBlock Text="Json" VerticalAlignment="Center" />
                </StackPanel>
            </Expander.Header>
            <Expander.Styles>
                <Style Selector="Expander /template/ ToggleButton /template/ Border#ExpandCollapseChevronBorder">
                    <Setter Property="IsVisible" Value="True" />
                    <Setter Property="VerticalAlignment" Value="Top" />
                    <Setter Property="Margin" Value="0 10 0 0" />

                </Style>
                <Style Selector="Expander /template/ ToggleButton">
                    <Setter Property="Width" Value="50" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Margin" Value="0 0 0 0" />
                    <Setter Property="Padding" Value="0 0 0 0" />

                    <Setter Property="VerticalContentAlignment" Value="Top" />
                    <Setter Property="Template">
                        <!-- Identical to https://github.com/AvaloniaUI/Avalonia/blob/3111696698e2c3d6fe9aace8cb954153ee16b3e4/src/Avalonia.Themes.Fluent/Controls/Expander.xaml#L77 
                        other than:
                        * Grid.Column is 0.  Because they directly set it, it wasn't overridable, so changing it was impossible.
                        * Margin was removed since it was now a higher priority than what we could set with the Style/Property Override. -->
                        <ControlTemplate>
                            <Border x:Name="ToggleButtonBackground"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid x:Name="ToggleButtonGrid"
                                      ColumnDefinitions="*,Auto">
                                    <ContentPresenter x:Name="PART_ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Foreground="{TemplateBinding Foreground}"
                                                      Margin="{TemplateBinding Padding}" />
                                    <Border x:Name="ExpandCollapseChevronBorder"
                                            Grid.Column="0"
                                            Width="{DynamicResource ExpanderChevronButtonSize}"
                                            Height="{DynamicResource ExpanderChevronButtonSize}"
                                            CornerRadius="{DynamicResource ControlCornerRadius}"
                                            BorderBrush="{DynamicResource ExpanderChevronBorderBrush}"
                                            BorderThickness="{DynamicResource ExpanderChevronBorderThickness}"
                                            Background="{DynamicResource ExpanderChevronBackground}">
                                        <Path x:Name="ExpandCollapseChevron"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RenderTransformOrigin="50%,50%"
                                              Stretch="None"
                                              Stroke="{DynamicResource ExpanderChevronForeground}"
                                              StrokeThickness="1">
                                            <Path.RenderTransform>
                                                <RotateTransform />
                                            </Path.RenderTransform>
                                        </Path>
                                    </Border>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter>
                </Style>

                <Style Selector="Expander /template/ DockPanel">
                    <Setter Property="MaxWidth" Value="50" />
                </Style>
            </Expander.Styles>
            <Expander.Background>
                <ImageBrush Source="avares://E33Randomizer/Assets/Images/JsonExportViewBackground.png" Stretch="Fill"
                            Opacity="0.7" />
            </Expander.Background>
            <TextBox
                Text="{Binding Json}"
                IsReadOnly="True"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                Width="400"
                FontFamily="TimesNewRoman"
                Margin="5" />

        </Expander>
    </DockPanel>
</Window>